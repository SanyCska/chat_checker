# Get from https://my.telegram.org  (API development tools)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Phone number for the user account (with country code)
PHONE_NUMBER=+79001234567

# Get from @BotFather in Telegram
BOT_TOKEN=1111111

# Your personal Telegram user ID (get from @userinfobot)
NOTIFY_USER_ID=11111

# Supergroup chat ID (for https://t.me/c/3899039929/... it's -1003899039929)
# If Telethon can't resolve the id on first run, open this chat once in Telegram on this account.
CHAT_ID=-11111

# Topic/thread ID from the link (2 from https://t.me/c/3899039929/2)
# Set 0 to monitor the whole chat without topic filtering.
TOPIC_ID=2

# Optional: on startup, scan last N chat messages and log up to M messages from TOPIC_ID
# STARTUP_HISTORY_SCAN=200
# STARTUP_TOPIC_PREVIEW=8
